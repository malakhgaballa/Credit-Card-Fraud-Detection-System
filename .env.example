# FraudShield API Configuration
# Copy this file to .env and update with your values

# ============ API Configuration ============
API_TITLE=FraudShield Fraud Detection API
API_VERSION=1.0.0
API_ENVIRONMENT=development

# ============ Database Configuration ============
# PostgreSQL connection string
DATABASE_URL=postgresql://fraudshield_user:password@localhost:5432/fraudshield_db

# ============ Redis Configuration ============
REDIS_URL=redis://localhost:6379

# ============ SSO Configuration ============
# Options: okta, azure, keycloak
SSO_PROVIDER=okta
SSO_DOMAIN=https://your-domain.okta.com
SSO_CLIENT_ID=your_client_id_here
SSO_CLIENT_SECRET=your_client_secret_here

# ============ JWT Configuration ============
JWT_SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
TOKEN_EXPIRY_MINUTES=60

# ============ ML Model Configuration ============
MODEL_PATH=./models/fraud_detection_model.pkl
MODEL_THRESHOLD=0.5

# ============ Logging & Monitoring ============
LOG_LEVEL=INFO
ENABLE_METRICS=true
METRICS_PORT=9090

# ============ CORS Configuration ============
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,https://fraudshield.yourdomain.com

# ============ Email Configuration (for alerts) ============
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
ALERT_EMAIL_FROM=alerts@fraudshield.com

# ============ Security Settings ============
# PII Encryption key (32 bytes hex string)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key
ENCRYPTION_ENABLED=true
